# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# JWT Secret for auth tokens
JWT_SECRET=change-this-to-a-random-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email) — set EMAIL_FROM to a verified sender; onboarding@resend.dev only works for the account owner's email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=BlackBox Logistics <noreply@yourdomain.com>

# Paystack — use test keys (pk_test_...) during development
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
